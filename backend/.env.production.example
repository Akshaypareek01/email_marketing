# ============================================================================
# PRODUCTION environment template.  Copy to your server as `.env` and fill in
# every <REPLACE_*> value.  Do NOT commit a filled-in copy.
#
#   cp .env.production.example .env   # on the production host, then edit
#
# The app FAILS TO BOOT in production if JWT_SECRET / CREDENTIALS_ENCRYPTION_KEY
# are missing/weak, if CORS_ORIGIN is "*", or if SNS verification is disabled.
# ============================================================================

PORT=4000
NODE_ENV=production
LOG_LEVEL=info

# --- Secrets (generate fresh, keep private — DO NOT commit real values) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=<REPLACE_RANDOM_32PLUS_CHARS>
# Dedicated key for encrypting mailbox IMAP passwords (separate from JWT_SECRET).
# NOTE: if you already stored credentials with the JWT-derived key, re-encrypt them.
CREDENTIALS_ENCRYPTION_KEY=<REPLACE_SEPARATE_RANDOM_32PLUS_CHARS>

JWT_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PASSWORD_RESET_EXPIRES_IN=1h
EMAIL_VERIFICATION_EXPIRES_IN=24h
REQUIRE_EMAIL_VERIFICATION=true

# --- Database ---
MONGODB_URI=<REPLACE_MONGODB_URI>            # e.g. mongodb+srv://user:pass@cluster/mailbox

# --- Public URLs (real https domains, comma-separated CORS allowlist) ---
CORS_ORIGIN=https://<REPLACE_FRONTEND_DOMAIN>
APP_URL=https://<REPLACE_FRONTEND_DOMAIN>
API_PUBLIC_URL=https://<REPLACE_API_DOMAIN>/api

# --- AWS SES (outbound).  Prefer an IAM role over static keys when possible. ---
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=<REPLACE_AWS_ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<REPLACE_AWS_SECRET_ACCESS_KEY>

# --- SES event pipeline (REQUIRED for bounce/complaint auto-suspend to work) ---
SES_CONFIG_SETS_ENABLED=true
SES_SNS_TOPIC_ARN=   # arn:aws:sns:ap-south-1:ACCOUNT:mailbox-ses-events
SES_VERIFY_SNS_SIGNATURE=true                 # also auto-forced on when NODE_ENV=production
SES_SYNC_SUPPRESSIONS=true

# Reputation tripwires (defaults shown; tune if needed)
# SES_COMPLAINT_ABS_LIMIT=5
# SES_BOUNCE_ABS_LIMIT=10

# Platform-wide 24h total send cap (super-admin can change live in the admin panel).
# 0 = unlimited. Default 50000.
PLATFORM_DAILY_SEND_LIMIT=50000

# --- Outbound-only mode (no inbound mailbox provisioning) ---
INBOUND_EMAIL_ENABLED=false
PLATFORM_MX_HOST=<REPLACE_OR_LEAVE_DEFAULT>

# IMAP inbox sync — only needed if INBOUND_EMAIL_ENABLED=true. Keep TLS verification ON.
IMAP_TLS_INSECURE=false
# IMAP_HOST=
# IMAP_USER=
# IMAP_PASSWORD=
# IMAP_SYNC_FOLDERS=INBOX,Junk Mail

# Real-time inbound webhook (only if used)
INBOUND_WEBHOOK_SECRET=<REPLACE_RANDOM_SECRET>
# INBOUND_WEBHOOK_PUBLIC_URL=https://<REPLACE_API_DOMAIN>

# --- Redis (REQUIRED in production so the rate limiter is shared across instances) ---
REDIS_URL=<REPLACE_REDIS_URL>                # e.g. redis://default:pass@host:6379

# --- Billing (use LIVE provider keys, not test) ---
BILLING_MODE=provider
BILLING_PROVIDER=razorpay
RAZORPAY_KEY_ID=<REPLACE_LIVE_RAZORPAY_KEY_ID>           # rzp_live_...
RAZORPAY_KEY_SECRET=<REPLACE_LIVE_RAZORPAY_KEY_SECRET>
RAZORPAY_WEBHOOK_SECRET=<REPLACE_RAZORPAY_WEBHOOK_SECRET> # REQUIRED or webhooks fail closed
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
CAMPAIGN_SEND_RATE=5
BILLING_GRACE_DAYS=7
SOFT_BOUNCE_THRESHOLD=3

# --- Transactional sender (must be a verified SES identity) ---
PLATFORM_FROM_EMAIL=<REPLACE_VERIFIED_FROM_EMAIL>
PLATFORM_FROM_NAME=Mail Box

# --- Cloudflare R2 — KYC documents MUST live in a PRIVATE bucket ---
# Use a dedicated bucket with public access DISABLED. Leave R2_PUBLIC_URL blank for KYC.
R2_ACCESS_KEY_ID=<REPLACE_R2_ACCESS_KEY_ID>
R2_SECRET_ACCESS_KEY=<REPLACE_R2_SECRET_ACCESS_KEY>
R2_ENDPOINT=https://<REPLACE_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET_NAME=<REPLACE_PRIVATE_BUCKET_NAME>
R2_PUBLIC_URL=

# --- KYC policy ---
KYC_REQUIRED=true
KYC_UPLOAD_URL_TTL=300
KYC_VIEW_URL_TTL=120
KYC_MAX_FILE_BYTES=5242880
KYC_SEND_LIMIT_BEFORE_KYC=200

# --- Super-admin seed (run once: npm run seed:admin) ---
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=<REPLACE_ADMIN_EMAIL>
SEED_ADMIN_PASSWORD=<REPLACE_STRONG_ADMIN_PASSWORD>

# Optional master kill switch
# PLATFORM_SENDING_HALTED=false
