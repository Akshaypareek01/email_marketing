PORT=4000
# Set to "production" to enable fail-fast secret checks, forced SNS verification, trust-proxy.
NODE_ENV=development
# info in production; debug only for local dev (never gates secret exposure anymore).
LOG_LEVEL=info
# Dedicated key for encrypting mailbox IMAP passwords. STRONGLY recommended in production
# (falls back to JWT_SECRET if unset). Use a random 32+ byte value.
CREDENTIALS_ENCRYPTION_KEY=
MONGODB_URI=mongodb://localhost:27017/mailbox
# REQUIRED in production: random, >= 32 characters. Startup fails if weak/default.
JWT_SECRET=change-me-in-production-min-32-characters
JWT_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PASSWORD_RESET_EXPIRES_IN=1h
EMAIL_VERIFICATION_EXPIRES_IN=24h
# REQUIRE_EMAIL_VERIFICATION=true
CORS_ORIGIN=http://localhost:3000

# AWS SES (outbound)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Stalwart (inbox / JMAP)
STALWART_API_URL=https://stalwart.espanda.ai
# Optional — auto-discovered from /.well-known/jmap if unset
STALWART_JMAP_URL=
STALWART_ADMIN=admin
STALWART_PASSWORD=
STALWART_API_KEY=

# Platform mail routing (MX target — inbound only when INBOUND_EMAIL_ENABLED=true)
PLATFORM_MX_HOST=mail.espanda.ai

# Outbound-only: skip Stalwart/inbox; SES send from verified domains.
INBOUND_EMAIL_ENABLED=false

# IMAP — sync mailbox into MongoDB (IMAP_USER must match a Mailbox.address)
IMAP_HOST=3.111.147.182
IMAP_PORT=993
# IMAP_SECURE=false
IMAP_TLS_INSECURE=true
IMAP_USER=test@espanda.ai
IMAP_PASSWORD=
IMAP_SYNC_FOLDERS=INBOX,Junk Mail
IMAP_DEBUG=false

# Real-time inbound (generate: openssl rand -hex 24)
INBOUND_WEBHOOK_SECRET=
# Public base URL Stalwart can POST to (prod API URL; local: ngrok http 4000)
INBOUND_WEBHOOK_PUBLIC_URL=http://localhost:4000
# Stalwart WebUI → Settings → Telemetry → Webhooks:
#   URL: {INBOUND_WEBHOOK_PUBLIC_URL}/api/email/webhooks/stalwart
#   Events (include): message-ingest.ham, message-ingest.spam
#   HTTP Auth: Bearer <INBOUND_WEBHOOK_SECRET>
#   OR header: X-Inbound-Webhook-Secret: <INBOUND_WEBHOOK_SECRET>

# Public app + API URLs (unsubscribe, billing redirects)
APP_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000/api

# Redis + BullMQ campaign worker (omit for in-process fallback)
REDIS_URL=redis://localhost:6379

# SES per-tenant configuration sets
SES_CONFIG_SETS_ENABLED=false
# SES_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:mailbox-ses-events

# Billing + campaign throttle
BILLING_MODE=provider
BILLING_PROVIDER=razorpay
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
CAMPAIGN_SEND_RATE=5

# Platform transactional email (verify/reset links)
PLATFORM_FROM_EMAIL=
PLATFORM_FROM_NAME=Mail Box

BILLING_GRACE_DAYS=7
SOFT_BOUNCE_THRESHOLD=3

# SNS signature verification — forced ON automatically when NODE_ENV=production.
# SES_VERIFY_SNS_SIGNATURE=true

# Absolute-count auto-pause tripwires (fire regardless of sample size — protects the
# shared AWS SES account from a brand-new tenant blasting a spam-trap list).
# SES_COMPLAINT_ABS_LIMIT=5
# SES_BOUNCE_ABS_LIMIT=10

# Sync AWS account suppression list into global suppressions (hourly job)
SES_SYNC_SUPPRESSIONS=false

# Platform auto-protect (PRD §6.4) — pause highest-risk tenants when aggregate nears AWS limits
# SES_PLATFORM_PROTECT_RATIO=0.75
# SES_PLATFORM_MIN_SAMPLE=200
# SES_PLATFORM_MAX_PAUSES=3
# PLATFORM_REPUTATION_JOB_MS=300000

# Seed super admin (npm run seed:admin)
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Platform reputation job tuning
# PLATFORM_REPUTATION_DEBOUNCE_MS=8000

# SES reputation guardrails (optional — defaults in src/config/env.js)
# SES_BOUNCE_RATE_LIMIT=0.05
# SES_COMPLAINT_RATE_LIMIT=0.001
# SES_WARN_RATIO=0.6
# SES_PAUSE_RATIO=0.8
# SES_MIN_SAMPLE_SIZE=50
# SES_WINDOW_DAYS=14

# Master kill switch for all outbound sending
# PLATFORM_SENDING_HALTED=false

# Default platform-wide 24h total send cap (super-admin can change live in the admin panel).
# 0 = unlimited. Protects the shared AWS SES account.
# PLATFORM_DAILY_SEND_LIMIT=50000

# Prod SNS → SES events: see docs/SNS-PRODUCTION-SETUP.md

# Cloudflare R2 — PRIVATE bucket for KYC documents (S3-compatible).
# Use a dedicated bucket with public access DISABLED. Leave R2_PUBLIC_URL blank
# for KYC; it is only for non-sensitive public assets. See docs/KYC-VERIFICATION-FLOW.md
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_BUCKET_NAME=mailbox-kyc
R2_PUBLIC_URL=

# KYC (business verification) policy
KYC_REQUIRED=true
KYC_UPLOAD_URL_TTL=300        # presigned PUT lifetime, seconds
KYC_VIEW_URL_TTL=120          # presigned GET (admin view) lifetime, seconds
KYC_MAX_FILE_BYTES=5242880    # 5 MB
KYC_SEND_LIMIT_BEFORE_KYC=200 # free emails before KYC required (0 = block immediately)
